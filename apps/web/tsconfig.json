{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["@cloudflare/workers-types", "vite/client"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.vue",
    "server/**/*.ts",
    "drizzle.config.ts",
    "vite.config.ts",
    "env.d.ts"
  ]
}
