{
  "name": "@tete/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy",
    "typecheck": "vue-tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply tete --local",
    "db:migrate:remote": "wrangler d1 migrations apply tete --remote",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@tete/shared": "*",
    "better-auth": "^1.6.20",
    "dayjs": "^1.11.21",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.14",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.0",
    "@cloudflare/workers-types": "^4.20241218.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vue-tsc": "^2.2.0",
    "wrangler": "^4.0.0"
  }
}
